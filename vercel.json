{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/logo.png", "dest": "/logo.png" },
    { "src": "/logo.svg", "dest": "/logo.svg" },
    { "src": "/truck_hero.png", "dest": "/truck_hero.png" },
